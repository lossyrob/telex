{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "powershell": "telex --json copilot session-end",
        "bash": "telex --json copilot session-end",
        "timeoutSec": 30
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "powershell": "telex --json copilot turn-guard",
        "bash": "telex --json copilot turn-guard",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "powershell": "& (Join-Path $env:COPILOT_PLUGIN_ROOT 'drain-hook.ps1')",
        "bash": "sh \"$COPILOT_PLUGIN_ROOT/drain-hook.sh\"",
        "timeoutSec": 30
      }
    ]
  }
}
