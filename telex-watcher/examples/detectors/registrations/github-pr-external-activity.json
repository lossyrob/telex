{
  "id": "example-github-pr-external-activity",
  "command": [
    "pwsh",
    "-NoLogo",
    "-NoProfile",
    "-File",
    "C:\\path\\to\\telex-watcher\\examples\\detectors\\scripts\\gh-pr-external-activity-detector.ps1"
  ],
  "scriptPath": "C:\\path\\to\\telex-watcher\\examples\\detectors\\scripts\\gh-pr-external-activity-detector.ps1",
  "workingDirectory": "C:\\path\\to\\telex-watcher\\examples\\detectors\\scripts",
  "scriptMode": "follow-path",
  "sender": "watcher@example.invalid",
  "target": "recipient@example.invalid",
  "intervalSeconds": 300,
  "timeoutSeconds": 30,
  "attention": "next-checkpoint",
  "requiresDisposition": false,
  "environmentAllowlist": [
    "GH_TOKEN"
  ],
  "parameters": {
    "repository": "OWNER/REPOSITORY",
    "pullRequestNumber": 123,
    "selfLogin": "YOUR-GITHUB-LOGIN",
    "ignoredLogins": [
      "example-bot"
    ],
    "emitInitialSnapshot": false
  },
  "state": {}
}
